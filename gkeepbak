#!/usr/bin/env python3
"""
gkeepbak
  read old state backup file, sync with api, make new backup

desc:
  - maintains zstd-compressed backups of google keep data
  - globs backup files in arg1 dir, reads most recent serialized state
  - if no backup files, obtain keep data anew from api (expensive)
  - otherwise, uses api to sync from upstream, does incremental download
  - requires $GKEEPBAK_EMAIL for account, $GKEEPBAK_TOKEN for master token

deps:
  - https://github.com/kiwiz/gkeepapi/

"""
__url__     = 'https://github.com/smemsh/utilpy/'
__author__  = 'Scott Mcdermott <scott@smemsh.net>'
__license__ = 'GPL-2.0'
__devskel__ = '0.8.1'

from sys import exit, hexversion
if hexversion < 0x030e00f0: exit("minpython: %s" % hexversion)

import argparse

from compression import zstd
from select import select
from shutil import which
from glob import glob
from sys import argv, stdin, stdout, stderr

from json import dumps, load
from json.decoder import JSONDecodeError

from os.path import basename, dirname, isdir, exists, abspath
from os import (
    getenv, unsetenv,
    getcwd, chdir, makedirs,
    access, R_OK, W_OK,
    close as osclose,
    EX_OK as EXIT_SUCCESS,
    EX_SOFTWARE as EXIT_FAILURE,
)

from datetime import datetime as dt

import gkeepapi

###

def err(*args, **kwargs):
    print(*args, file=stderr, **kwargs)

def bomb(*args, **kwargs):
    err(*args, **kwargs)
    exit(EXIT_FAILURE)

###

def process_args():

    global args

    def addarg(p, vname, help=None, /, **kwargs):
        p.add_argument(vname, help=help, **kwargs)

    p = argparse.ArgumentParser(
        prog            = invname,
        description     = __doc__.strip(),
        allow_abbrev    = False,
        formatter_class = argparse.RawTextHelpFormatter,
    )
    addarg(p, 'bakdir')
    args = p.parse_args(args)
    bakdir = args.bakdir or getcwd()

    return abspath(bakdir.rstrip('/'))


def check_sanity(dest):

    if not isdir(dest):
        bomb(f"backup directory '{dest}' invalid")

    if not exists(dest):
        try: makedirs(dest)
        except: bomb(f"backup dir '{dest}' dne or bad mkdir")

    elif not isdir(dest):
        bomb(f"refusing overwrite of '{dest}' (not a directory)")

    if not access(dest, W_OK):
        bomb(f"cannot write to destdir '{dest}'")


def gkeepbak(bakdir):

    (authtok := getenv('GKEEPBAK_TOKEN')) or bomb("authtok unset")
    (email := getenv('GKEEPBAK_EMAIL')) or bomb("email unset")

    keep = gkeepapi.Keep()

    chdir(bakdir)
    if statefiles := glob('state-20????????????.json.zst'):
        latest = sorted(statefiles)[-1]
        infile = open(latest, 'rb')
        zinfile = zstd.open(infile)
        try: olddata = load(zinfile)
        except JSONDecodeError:
            bomb(f"problem parsing json from {latest}")
    else:
        err("initial run, full download")
        olddata = None

    keep.authenticate(email, authtok, state=olddata)
    newdata = keep.dump()

    # todo: not used at the moment, see commented-out err() below
    fn = lambda f: f['timestamps']['updated']
    oldlast = fn(sorted(olddata['nodes'], key=fn)[-1])
    newlast = fn(sorted(newdata['nodes'], key=fn)[-1])

    # todo: updated timestamp seems to always change, even with no changes to
    # the data itself.  so we never actually take this branch.  need to do a
    # full-struct comparison, less the timestamp.
    #
    if oldlast == newlast:
        exit(EXIT_SUCCESS)

    fmt = "%Y%m%d%H%M%S"
    old = dt.fromisoformat(oldlast)
    new = dt.fromisoformat(newlast)
    now = dt.now().strftime(fmt)
    stamp = new.strftime(fmt)
    since = (new - old).total_seconds() / 60 / 60
    #err(f"newest: {stamp}, since: {since:0.2g} hours")

    outfile = open(f"state-{now}.json.zst", 'wb')
    zoutfile = zstd.open(outfile, 'w')
    # json.load() supports bytes, but .dump() can only write strings
    #dump(newdata, zoutfile)
    newbytes = dumps(newdata).encode()
    zoutfile.write(newbytes)
    zoutfile.close()


def main():

    if debug == 1:
        breakpoint()

    bakdir = process_args()
    check_sanity(bakdir)

    try: subprogram = globals()[invname]
    except (KeyError, TypeError):
        from inspect import trace
        if len(trace()) == 1: bomb("unimplemented")
        else: raise

    return subprogram(bakdir)

