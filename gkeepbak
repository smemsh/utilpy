#!/usr/bin/env python3
"""
gkeepbak
  read old state backup file, compare to api, make new backup if changed

desc:
  - maintains zstd-compressed backups of google keep data
  - globs backup files in arg1 dir, reads most recent serialized state
  - if no backup files, obtain keep data anew from api (expensive)
  - otherwise, uses api to sync from upstream, does incremental download
  - if changed records, write new serialized json for comparison next time
  - requires $GKEEPBAK_EMAIL for account, $GKEEPBAK_TOKEN for master token

deps:
  - https://github.com/kiwiz/gkeepapi/

"""
